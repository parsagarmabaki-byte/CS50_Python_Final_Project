# Docker Compose Environment Variables
# Copy this file to .env and update with your server IP

# Your Ubuntu server IP address (required)
# Find it with: hostname -I
SERVER_IP=192.168.1.100

# Ports (optional - change if needed)
BACKEND_PORT=8000
FRONTEND_PORT=80

# Build arguments
VITE_API_BASE_URL=http://${SERVER_IP}:8000
